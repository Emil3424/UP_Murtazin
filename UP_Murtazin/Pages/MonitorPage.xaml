<Page x:Class="UP_Murtazin.Pages.MonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      Title="Монитор торговых автоматов"
      Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Монитор торговых автоматов" 
                   FontSize="24" FontWeight="Bold" 
                   Foreground="#1976D2" Margin="0,0,0,20"/>

        <!-- Панель фильтров -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                CornerRadius="4" Padding="15" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Общее состояние -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="Общее состояние" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="StatusGreen" BorderBrush="#4CAF50" BorderThickness="2" 
                                CornerRadius="4" Padding="10,5" Margin="0,0,10,0" Cursor="Hand"
                                MouseDown="StatusFilter_Click" Tag="Работает">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16" Height="16" Fill="#4CAF50"/>
                                    <TextBlock Text="Работает" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="StatusRed" BorderBrush="#F44336" BorderThickness="2" 
                                CornerRadius="4" Padding="10,5" Margin="0,0,10,0" Cursor="Hand"
                                MouseDown="StatusFilter_Click" Tag="Сломан">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16" Height="16" Fill="#F44336"/>
                                    <TextBlock Text="Сломан" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="StatusBlue" BorderBrush="#2196F3" BorderThickness="2" 
                                CornerRadius="4" Padding="10,5" Margin="0,0,10,0" Cursor="Hand"
                                MouseDown="StatusFilter_Click" Tag="Обслуживается">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16" Height="16" Fill="#2196F3"/>
                                    <TextBlock Text="Обслуживается" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Сортировка" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ComboBox x:Name="CmbSort" Width="200" Height="30">
                            <ComboBoxItem Content="По номеру" IsSelected="True"/>
                            <ComboBoxItem Content="По состоянию ТА"/>
                            <ComboBoxItem Content="По названию"/>
                            <ComboBoxItem Content="По сумме денег"/>
                            <ComboBoxItem Content="По загрузке"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="20,0,0,0">
                        <TextBlock Text="Действия" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Применить" Width="100" Height="35" Margin="0,0,15,0"
                                Background="#1976D2" Foreground="White" 
                                BorderThickness="0" 
                                Click="ApplyFilter_Click"/>
                            <Button Content="Очистить" Width="100" Height="35" 
                                Background="#E0E0E0" Foreground="Black" 
                                BorderThickness="0"
                                Click="ClearFilter_Click"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица автоматов -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                CornerRadius="4" Margin="0,0,0,20">
            <DataGrid x:Name="MachinesGrid" AutoGenerateColumns="False" 
                          CanUserAddRows="False" CanUserSortColumns="True"
                          RowHeight="80" BorderThickness="0"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFAFA">
                <DataGrid.Columns>
                    <!-- № -->
                    <DataGridTextColumn Header="#" Binding="{Binding Number}" Width="40">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Торговый автомат -->
                    <DataGridTemplateColumn Header="Торговый автомат" Width="auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,5">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding Model}" FontSize="11" Foreground="#666"/>
                                    <TextBlock Text="{Binding Address}" FontSize="11" Foreground="#999"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding Status}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Связь (оператор + сигнал) -->
                    <DataGridTemplateColumn Header="Связь" Width="auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,5" HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Image Source="{Binding SignalIcon}" Width="32" Height="32" Margin="10,5"/>
                                    <Image Source="{Binding OperatorIcon}" Width="48" Height="48" Margin="0,0,0,5"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Загрузка с прогресс-баром -->
                    <DataGridTemplateColumn Header="Загрузка" Width="auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,5">
                                    <TextBlock Text="Общая загрузка" FontSize="10" Foreground="#666"/>
                                    <ProgressBar Value="{Binding LoadPercentage}" 
                                                     Minimum="0" Maximum="100" 
                                                     Height="10" Width="120"
                                                     Foreground="{Binding LoadColor}">
                                        <ProgressBar.Resources>
                                            <Style TargetType="ProgressBar">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                            </Style>
                                        </ProgressBar.Resources>
                                    </ProgressBar>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding LoadPercentage, StringFormat={}{0:F0}%}" 
                                                   FontSize="11" HorizontalAlignment="Center" Margin="5,0,60,0"/>
                                        <TextBlock Text="{Binding LoadText}" FontSize="10" 
                                                   Foreground="{Binding LoadColor}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Денежные средства из rfid_services.total_income -->
                    <DataGridTemplateColumn Header="Денежные средства" Width="auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,5">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <Image Source="/Resources/States/Bills.png" Width="20" Height="20" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding TotalIncome, StringFormat={}{0:N2} р.}" 
                                                       FontWeight="Bold" FontSize="14" Foreground="#2E7D32"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Resources/OtherIcons/Cash.png" Width="20" Height="20" Margin="0,0,5,0"/>
                                        <TextBlock Text="Наличные: " FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding CashAmount, StringFormat={}{0:N2} р.}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Resources/States/Change.png" Width="20" Height="20" Margin="0,0,5,0"/>
                                        <TextBlock Text="Монеты: " FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding CoinCount, StringFormat={}{0} шт.}" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- События -->
                    <DataGridTemplateColumn Header="Последнее событие" Width="auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,5">
                                    <TextBlock Text="{Binding LastEventTime, StringFormat={}{0:dd.MM HH:mm}}" 
                                                   FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding LastEventType}" FontSize="10" Foreground="#666" 
                                                   TextWrapping="Wrap" MaxWidth="120"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Оборудование -->
                    <DataGridTemplateColumn Header="Оборудование" Width="auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="10,5" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CoinStatus}" FontSize="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding BillStatus}" FontSize="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding CardStatus}" FontSize="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding DispenserStatus}" FontSize="14"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Итоговая информация -->
        <Border Grid.Row="4" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                CornerRadius="4" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Итого автоматов: " FontWeight="Bold"/>
                    <TextBlock x:Name="TxtTotalMachines" Text="0" FontWeight="Bold" Foreground="#1976D2"/>
                    <TextBlock Text=" (" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtWorkingMachines" Text="0" FontWeight="Bold" Foreground="#4CAF50"/>
                    <TextBlock Text=" / " FontWeight="Bold"/>
                    <TextBlock x:Name="TxtOfflineMachines" Text="0" FontWeight="Bold" Foreground="#F44336"/>
                    <TextBlock Text=" / " FontWeight="Bold"/>
                    <TextBlock x:Name="TxtMaintenanceMachines" Text="0" FontWeight="Bold" Foreground="#2196F3"/>
                    <TextBlock Text="), Денег в автоматах: " FontWeight="Bold"/>
                    <TextBlock x:Name="TxtTotalMoney" Text="0" FontWeight="Bold" Foreground="#4CAF50"/>
                    <TextBlock Text=" р." FontWeight="Bold"/>
                </StackPanel>

                <Button Grid.Column="1" Content="📊 Экспорт в Excel" 
                        Background="#4CAF50" Foreground="White" 
                        BorderThickness="0" Padding="15,8"
                        Click="ExportToExcel_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>