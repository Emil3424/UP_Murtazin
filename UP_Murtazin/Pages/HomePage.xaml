<Page x:Class="UP_Murtazin.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DashboardPage"
      Background="{StaticResource BackgroundBrush}"
      Loaded="Page_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="ООО Торговые Автоматы" FontSize="24" FontWeight="Bold" 
                       Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,5"/>
            <TextBlock Text="Личный кабинет. Главная" Style="{StaticResource SubtitleStyle}" Margin="0,0,0,20"/>

            <!-- Дата обновления данных -->
            <TextBlock x:Name="LastUpdateDate" Text="Данные актуальны на: " 
                       FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Эффективность сети с полукруглым прогрессом -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Эффективность сети" Style="{StaticResource SectionTitleStyle}" FontSize="16"/>
                        <Grid Height="120" Margin="0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Полукруглый прогресс бар -->
                            <Viewbox Grid.Row="0" Width="100" Height="60" HorizontalAlignment="Center">
                                <Grid Width="100" Height="60">
                                    <Path Fill="LightGray" Stroke="LightGray" StrokeThickness="0">
                                        <Path.Data>
                                            <PathGeometry>
                                                <PathFigure StartPoint="10,50" IsClosed="True">
                                                    <ArcSegment Point="90,50" Size="40,40" SweepDirection="Clockwise" IsLargeArc="False"/>
                                                    <LineSegment Point="90,60"/>
                                                    <ArcSegment Point="10,60" Size="40,50" SweepDirection="Counterclockwise" IsLargeArc="False"/>
                                                    <LineSegment Point="10,50"/>
                                                </PathFigure>
                                            </PathGeometry>
                                        </Path.Data>
                                    </Path>
                                    <Path x:Name="ProgressPath" Stroke="#27AE60" StrokeThickness="8" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                        <Path.Data>
                                            <PathGeometry>
                                                <PathFigure StartPoint="10,50">
                                                    <ArcSegment x:Name="ProgressArc" Point="10,50" Size="40,40" SweepDirection="Clockwise"/>
                                                </PathFigure>
                                            </PathGeometry>
                                        </Path.Data>
                                    </Path>
                                    <TextBlock x:Name="WorkingMachinesPercent" Text="0%" FontSize="20" FontWeight="Bold" 
                                               Foreground="#27AE60" VerticalAlignment="Bottom" Margin="0,30,0,0"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </Viewbox>

                            <TextBlock Grid.Row="1" x:Name="WorkingMachinesCount" Text="Работающих автоматов: 0 из 0" 
                                       FontSize="16" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Состояние сети с круговым прогрессом -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Состояние сети" Style="{StaticResource SectionTitleStyle}" FontSize="16" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Круговой прогресс бар с разноцветными секторами -->
                            <Grid Grid.Column="0" Width="100" Height="100" Margin="0,0,15,0">
                                <!-- Фоновый круг -->
                                <Ellipse Stroke="#E4E7EB" StrokeThickness="8" Width="100" Height="100"/>

                                <!-- Сектор "Работает" (зеленый) -->
                                <Path x:Name="WorkingSector" Fill="Transparent" Stroke="#27AE60" StrokeThickness="8" 
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                                <!-- Сектор "Обслуживается" (оранжевый) -->
                                <Path x:Name="MaintenanceSector" Fill="Transparent" Stroke="#F39C12" StrokeThickness="8" 
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                                <!-- Сектор "Сломан" (красный) -->
                                <Path x:Name="BrokenSector" Fill="Transparent" Stroke="#E74C3C" StrokeThickness="8" 
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                                <TextBlock x:Name="TotalMachinesCount" Text="0" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Легенда -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Rectangle Width="12" Height="12" Fill="#27AE60" Margin="0,0,8,0"/>
                                    <TextBlock Text="Работает" FontSize="16" Foreground="#2C3E50"/>
                                    <TextBlock x:Name="WorkingCount" Text="0" FontSize="16" FontWeight="Bold" Margin="8,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Rectangle Width="12" Height="12" Fill="#F39C12" Margin="0,0,8,0"/>
                                    <TextBlock Text="Обслуживается" FontSize="16" Foreground="#2C3E50"/>
                                    <TextBlock x:Name="MaintenanceCount" Text="0" FontSize="16" FontWeight="Bold" Margin="8,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Rectangle Width="12" Height="12" Fill="#E74C3C" Margin="0,0,8,0"/>
                                    <TextBlock Text="Сломан" FontSize="16" Foreground="#2C3E50"/>
                                    <TextBlock x:Name="BrokenCount" Text="0" FontSize="16" FontWeight="Bold" Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Сводка -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Сводка" Style="{StaticResource SectionTitleStyle}" FontSize="16"/>
                    <TextBlock x:Name="SummaryDate" Text="" FontSize="11" Foreground="#7F8C8D" Margin="0,5,0,15"/>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Левая колонка -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Денег в ТА" Style="{StaticResource StatsLabelStyle}" Margin="0,0,25,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="0" x:Name="MoneyInMachines" Text="0 р." Style="{StaticResource StatsValueStyle}" Margin="0,28,0,0"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Сдача в ТА" Style="{StaticResource StatsLabelStyle}" Margin="0,20,0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" x:Name="ChangeInMachines" Text="0 р." Style="{StaticResource StatsValueStyle}" Margin="0,48,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Выручка, сегодня" Style="{StaticResource StatsLabelStyle}" Margin="0,20,0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" x:Name="RevenueToday" Text="0 р." Style="{StaticResource StatsValueStyle}" Margin="0,48,0,0"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Выручка, вчера" Style="{StaticResource StatsLabelStyle}" Margin="0,20,0,5"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" x:Name="RevenueYesterday" Text="0 р." Style="{StaticResource StatsValueStyle}" Margin="0,48,0,0"/>

                        <!-- Правая колонка -->
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Инкассировано, сегодня" Style="{StaticResource StatsLabelStyle}" Margin="40,0,0,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CollectedToday" Text="0 р." Style="{StaticResource StatsValueStyle}" Margin="40,28,0,0"/>

                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Инкассировано, вчера" Style="{StaticResource StatsLabelStyle}" Margin="40,20,0,5"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CollectedYesterday" Text="0 р." Style="{StaticResource StatsValueStyle}" Margin="40,48,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Обслужено ТА, сег./вчера" Style="{StaticResource StatsLabelStyle}" Margin="40,20,0,5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ServicedToday" Text="0 / 0" Style="{StaticResource StatsValueStyle}" Margin="40,48,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Динамика продаж -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Динамика продаж за последние 10 дней" Style="{StaticResource SectionTitleStyle}" FontSize="16"/>
                    <TextBlock x:Name="SalesDateRange" Text="Данные по продажам" Style="{StaticResource SubtitleStyle}"/>

                    <!-- По сумме -->
                    <TextBlock Text="По сумме" FontWeight="Medium" Foreground="#2C3E50" Margin="0,20,0,8"/>
                    <Border Background="#F8F9FA" BorderBrush="#E4E7EB" 
                            BorderThickness="1" CornerRadius="6" Height="240" Margin="0,0,0,20">
                        <Canvas x:Name="SalesChartCanvas" Background="Transparent" Width="780" Height="220"/>
                    </Border>

                    <!-- По количеству -->
                    <TextBlock Text="По количеству" FontWeight="Medium" Foreground="#2C3E50" Margin="0,0,0,8"/>
                    <Border Background="#F8F9FA" BorderBrush="#E4E7EB" 
                            BorderThickness="1" CornerRadius="6" Height="240">
                        <Canvas x:Name="QuantityChartCanvas" Background="Transparent" Width="780" Height="220"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Новости -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Новости" Style="{StaticResource SectionTitleStyle}" FontSize="16"/>
                    <ListBox x:Name="NewsListBox" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Date}" 
                                               Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" 
                                               Foreground="{StaticResource PrimaryTextBrush}" 
                                               FontSize="13" TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>