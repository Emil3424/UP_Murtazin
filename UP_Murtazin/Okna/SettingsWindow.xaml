<Window x:Class="UP_Murtazin.Okna.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Border Style="{StaticResource CardStyle}" Padding="20">
            <StackPanel>
                <!-- Заголовок -->
                <TextBlock Text="Настройки" FontSize="24" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryTextBrush}" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Смена пароля -->
                <TextBlock Text="Смена пароля" FontSize="18" FontWeight="SemiBold" 
                           Margin="0,0,0,15"/>

                <TextBlock Text="Текущий пароль" Foreground="{StaticResource SecondaryTextBrush}"/>
                <PasswordBox x:Name="CurrentPasswordBox" 
                             Style="{StaticResource InputPasswordBoxStyle}" 
                             Margin="0,5,0,15"/>

                <TextBlock Text="Новый пароль" Foreground="{StaticResource SecondaryTextBrush}"/>
                <PasswordBox x:Name="NewPasswordBox" 
                             Style="{StaticResource InputPasswordBoxStyle}" 
                             Margin="0,5,0,15"/>

                <TextBlock Text="Подтверждение пароля" Foreground="{StaticResource SecondaryTextBrush}"/>
                <PasswordBox x:Name="ConfirmPasswordBox" 
                             Style="{StaticResource InputPasswordBoxStyle}" 
                             Margin="0,5,0,20"/>

                <Button Content="Сменить пароль" Style="{StaticResource PrimaryButtonStyle}"
                        Width="150" Height="35" Click="ChangePassword_Click"/>

                <TextBlock x:Name="MessageText" Foreground="#4CAF50" 
                           Margin="0,10,0,0" Visibility="Collapsed"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>