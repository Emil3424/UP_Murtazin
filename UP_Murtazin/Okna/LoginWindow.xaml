<Window x:Class="UP_Murtazin.Okna.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="700" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Border Background="{StaticResource CardBackgroundBrush}" 
                CornerRadius="12" Margin="20"
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1">
            <StackPanel Margin="30">
                <!-- Заголовок -->
                <TextBlock Text="Вход в систему" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <!-- Поле Email -->
                <TextBlock Text="Email" Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTextBox" Height="auto"
                         Style="{StaticResource InputTextBoxStyle}"
                         Margin="0,0,0,15"/>

                <!-- Поле Пароль -->
                <TextBlock Text="Пароль" Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Height="auto" 
                             Style="{StaticResource InputPasswordBoxStyle}"
                             Margin="0,0,0,20"/>

                <!-- Капча -->
                <Border Background="#F5F5F5" CornerRadius="8" Padding="15" >
                    <StackPanel>
                        <TextBlock Text="Подтверждение" FontWeight="SemiBold" 
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Margin="0,0,0,10"/>
                        <TextBlock x:Name="CaptchaText" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBox x:Name="CaptchaAnswerTextBox" 
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Height="auto" Margin="0,0,0,5"/>
                        <Button Content="Обновить капчу" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="120" Height="28" FontSize="11"
                                Click="RefreshCaptcha_Click"
                                HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>

                <!-- Кнопка входа -->
                <Button x:Name="LoginButton" Content="Войти" IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="45" Click="LoginButton_Click" Cursor="Hand"/>

                <!-- Сообщение об ошибке -->
                <TextBlock x:Name="ErrorText" 
                           Foreground="#F44336" 
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>